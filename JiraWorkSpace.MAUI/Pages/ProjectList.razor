@page "/project"

@using System.ComponentModel
@using System.ComponentModel.DataAnnotations;
@using System.Text.Json;
@using AntDesign.TableModels
@using JiraWorkSpace.MAUI.Data
@using System.Text
@using System.Diagnostics
@using JiraWorkSpace.MAUI.Data.Project
@inject NavigationManager NavigationManager

<Form Model="searchFormModel" @ref="_form" Name="advanced_search">
    <Row Gutter="24">
        <GridCol Span="6">
            <FormItem Label="项目">
                <Input @bind-Value="@context.ProjectName" Placeholder="ProjectName" />
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <Button Type="primary" HtmlType="button"  OnClick="NavigateToAdd">Add</Button>
            <Button Type="primary" HtmlType="submit">Search</Button>
            <Button Style="margin: 0 8px;" OnClick="()=>{_form?.Reset();}">Clear</Button>
        </GridCol>
    </Row>
</Form>

<Table @ref="table"
       TItem="ProjectModel"
       DataSource="@itemList"
       Size=TableSize.Small>
    <ChildContent>
        <Selection Key="@(context.ProjectName)" />
        <Column Field="@context.ProjectName" Sortable />
        <Column @bind-Field="@context.CodeDirectory" Sortable />
        <Column @bind-Field="@context.GitUrl" Sortable />
        <ActionColumn>
            <Space>
                <SpaceItem><Button Danger OnClick="()=>Delete(context.ProjectName)">Delete</Button></SpaceItem>
            </Space>
        </ActionColumn>
    </ChildContent>

    <PaginationTemplate>
        <div style="padding-top:10px;">
            <Row>
                <Col Span="8">
                共 @total 个
                </Col>
                <Col Span="8" Offset="8">
                <Pagination Class="my-custom-pagination"
                            Total="@total"
                            PageSize="pageSize"
                            Current="pageIndex"
                            ShowSizeChanger="@true"
                            OnChange="OnChange" />
                </Col>
            </Row>
        </div>
    </PaginationTemplate>
</Table>

<br />

<h5>selections:</h5>
@if (selectedRows != null && selectedRows.Any())
{
    <Button Danger Size="small" OnClick="@(e => { selectedRows = null; })">Clear</Button>

    @foreach (var selected in selectedRows)
    {
        <Tag @key="selected.ProjectName" Closable OnClose="e=>RemoveSelection(selected.ProjectName)">@selected.ProjectName</Tag>
    }
}

@code {
    public class SearchFormModel
    {
        public string ProjectName { get; set; }
    }

    AntDesign.Internal.IForm _form;
    SearchFormModel searchFormModel = new SearchFormModel();
    List<ProjectModel> itemList;

    private JiraWorkSpace.MAUI.Data.ConfigService<List<ProjectModel>> configService = new JiraWorkSpace.MAUI.Data.ConfigService<List<ProjectModel>>(nameof(ProjectModel));

    IEnumerable<ProjectModel> selectedRows;
    ITable table;

    int pageIndex = 1;
    int pageSize = 10;
    int total = 0;

    private void NavigateToAdd()
    {
        NavigationManager.NavigateTo("/project/setup", false);
    }

    protected override async Task OnInitializedAsync()
    {
        itemList = await GetProjectListAsync(pageIndex, pageSize);
        total = itemList.Count;
    }

    public Task<List<ProjectModel>> GetProjectListAsync(int pageIndex, int pageSize)
    {
        return Task.FromResult((configService.GetConfig() ?? new List<ProjectModel>()).Skip((pageIndex - 1) * pageSize).Take(pageSize).ToList());
    }

    public async Task OnChange(PaginationEventArgs args)
    {
        if (pageIndex != args.Page)
        {
            pageIndex = args.Page;
        }

        if (pageSize != args.PageSize)
        {
            pageSize = args.PageSize;
        }

        itemList = await GetProjectListAsync(pageIndex, pageSize);
        total = itemList.Count;
    }

    public void RemoveSelection(string key)
    {
        var selected = selectedRows.Where(x => x.ProjectName != key);
        selectedRows = selected;
    }

    private void Delete(string key)
    {
        itemList.RemoveAll(x => x.ProjectName == key);
        total = itemList.Count;
        configService.Save(itemList);
    }
}