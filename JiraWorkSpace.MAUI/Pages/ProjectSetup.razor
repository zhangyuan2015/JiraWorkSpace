@page "/project/setup"

@using System.Text.Json;
@using JiraWorkSpace.MAUI.Data
@using JiraWorkSpace.MAUI.Data.Project
@using JiraWorkSpace.MAUI.Data.Setup

<Form Model="@projectModel"
      OnFinish="OnFinish"
      OnFinishFailed="OnFinishFailed">
    <Divider Orientation="left">基本信息</Divider>
    <Row Gutter="24">
        <GridCol Span="8">
            <FormItem Label="项目名称">
                <Input @bind-Value="@context.ProjectName" />
            </FormItem>
        </GridCol>
        <GridCol Span="8">
            <FormItem Label="Code Directory">
                <Input @bind-Value="@context.CodeDirectory" />
            </FormItem>
        </GridCol>
        <GridCol Span="8">
            <FormItem Label="Git Url">
                <Input @bind-Value="@context.GitUrl" />
            </FormItem>
        </GridCol>
    </Row>

    <Divider Orientation="left">环境</Divider>
    <Row Gutter="24">
        <Table @ref="table"
               TItem="EnvironmentModel"
               DataSource="@environmentList"
               Size=TableSize.Small>
            <ChildContent>
                <Selection Key="@(context.Name)" />
                <Column Field="@context.Name" Sortable />
                <Column @bind-Field="@context.BranchName" Sortable />
                <Column @bind-Field="@context.Url" Sortable />
                <ActionColumn>
                    <Space>
                        <SpaceItem><Button Danger OnClick="()=>Delete(context.Name)">Delete</Button></SpaceItem>
                    </Space>
                </ActionColumn>
            </ChildContent>
        </Table>
    </Row>
    <FormItem WrapperColOffset="6" WrapperColSpan="12">
        <Button Type="@ButtonType.Primary" HtmlType="submit">
            保存
        </Button>
    </FormItem>
</Form>

@code
{
    ITable table;
    private List<ProjectModel> projectModelList;
    private ProjectModel projectModel;
    List<EnvironmentModel> environmentList;
    private JiraWorkSpace.MAUI.Data.ConfigService<List<ProjectModel>> configService = new JiraWorkSpace.MAUI.Data.ConfigService<List<ProjectModel>>(nameof(ProjectModel));

    /// <summary>
    ///
    /// </summary>
    /// <returns></returns>
    protected override async Task OnInitializedAsync()
    {
        projectModelList = configService.GetConfig() ?? new List<ProjectModel>();
        projectModel = projectModelList.FirstOrDefault();
        if (projectModel == null)
        {
            projectModel = new ProjectModel() { EnvironmentList = new List<EnvironmentModel>() };
            projectModelList.Add(projectModel);
        }
        else
        {
            environmentList = projectModel.EnvironmentList ?? new List<EnvironmentModel>();
        }
    }

    private void OnFinish(EditContext editContext)
    {
        configService.Save(projectModelList);
    }

    private void OnFinishFailed(EditContext editContext)
    {
        Console.WriteLine($"Failed:{JsonSerializer.Serialize(projectModel)}");
    }
}